{
  "expo": {
    "name": "thrail_app",
    "slug": "thrail_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "thrailapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.thrail_app"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "@maplibre/maplibre-react-native",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Thrail to use your location to show you on the map."
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b6dba09b-d80c-45d8-ad39-273c63ef2f4e"
      }
    }
  }
}
