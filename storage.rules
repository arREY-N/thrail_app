rules_version = '2';

service firebase.storage {
    match /b/{bucket}/o{
        match/users/{userId}/{allPaths=**} {
            allow read:
                if request.auth != null && (
                    request.auth.uid == userId
                    || request.auth.token.role == 'admin'
                    || request.auth.token == 'superadmin'
                );

            allow write:
                if request.auth != null &&
                request.auth.uid == userId;
        }
    }
}